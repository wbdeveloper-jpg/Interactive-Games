MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1543486647}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f60f366bad91eec4e8c8de40c76be6f7, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::HeroInMaking
  heroLevelCharacters:
  - {fileID: 2102804719}
  - {fileID: 336816944}
  - {fileID: 1772784589}
  - {fileID: 92958954}
  - {fileID: 666499971}
  - {fileID: 1040140359}
  entryDelay: 2
  talkingBool: IsTalking
  correctTrigger: Special
  sadTrigger: Sad
  heroLevelText: {fileID: 996554159}
  dialogueGroup: {fileID: 243054512}
  dialogueText: {fileID: 1464261556}
  narrationSource: {fileID: 1640367593}
  fallbackTypewriterSpeed: 0.03
  dialogueLineGap: 0.7
  introDialogues:
  - text: Hi friends! My name is Kiko, and I love meeting new people.
    audio: {fileID: 8300000, guid: a5a1aba89838e6840853df2553395111, type: 3}
  - text: I dream of becoming a true hero one day and helping everyone around me.
    audio: {fileID: 8300000, guid: bb97a5e56af5a2d4eb9dffe80b83621a, type: 3}
  - text: I learned that being honest makes a hero stronger and kinder inside.
    audio: {fileID: 8300000, guid: 90d812e2e386a424f86f1e6e3eca49d6, type: 3}
  - text: Will you be honest with me and help me become a real hero?
    audio: {fileID: 8300000, guid: 0feb130a41967a349a35d409c1395f10, type: 3}
  - text: Let's go
    audio: {fileID: 8300000, guid: b9be3aaad1fd4b949a494200cdb3d7c1, type: 3}
  outroDialoguesMax:
  - text: Thank you for being honest and helping me grow into a hero!
    audio: {fileID: 8300000, guid: 1b8c19ef79158d849ab8e226b6a8c3fe, type: 3}
  - text: "Your honesty made me stronger today\u2014great job!"
    audio: {fileID: 8300000, guid: b2de021c0bda734469aa09e8e6aa0d2b, type: 3}
  - text: With honest friends like you, heroes are made!
    audio: {fileID: 8300000, guid: f1b67e5d80dd1ee4298172917b321c22, type: 3}
  outroDialoguesMid:
  - text: Nice work! You're getting closer to becoming a true hero!
    audio: {fileID: 8300000, guid: bfa0a0311ffa8364095d8f0a2bd1a625, type: 3}
  - text: "Great job! Keep going\u2014you\u2019re improving every step!"
    audio: {fileID: 8300000, guid: b7a7dc44902af1041bcd8723b2ad170c, type: 3}
  outroDialoguesMin:
  - text: That's okay! Every hero learns by trying again!
    audio: {fileID: 8300000, guid: a245a58854e22664d9b85c049e19f6f2, type: 3}
  - text: "You can do better next time\u2014your hero journey just started!"
    audio: {fileID: 8300000, guid: f98e00d9caa187d44a3ae5e5bcde71af, type: 3}
  questionBoardGroup: {fileID: 1071690023}
  questionBoard: {fileID: 1071690020}
  questionText: {fileID: 76065365}
  replayAudioGroup: {fileID: 757836347}
  instruction: {fileID: 2056316385}
  yesButton: {fileID: 557112554}
  noButton: {fileID: 736368215}
  correctParticle: {fileID: 3262884166631552015}
  wrongParticle: {fileID: 51609337}
  cardBgParticle: {fileID: 2080409244}
  boardEntryDuration: 0.5
  boardRotateDuration: 0.6
  buttonPopDelay: 0.1
  afterAnswerDelay: 1.5
  gameOverGroup: {fileID: 1396425247}
  playAgainButton: {fileID: 1501545702}
  mainMenuButton: {fileID: 1454004876}
  gameOverFadeDuration: 0.4
  questions:
  - question: A boy finds a pencil under his desk in the classroom. He knows it is
      not his. He takes the pencil and gives it to the teacher instead of keeping
      it.
    questionAudio: {fileID: 8300000, guid: 1519341c4d0d10841b3de388bdc54124, type: 3}
    correctAnswerIndex: 0
  - question: A girl is playing at home and accidentally breaks a toy. When her parents
      ask what happened, she says she did not break it, even though she did.
    questionAudio: {fileID: 8300000, guid: 7b5e6cc6e18c637418c7f13e826a8dbf, type: 3}
    correctAnswerIndex: 1
  - question: A child forgets to finish homework before coming to school. When the
      teacher asks, the child tells the truth and says the homework is not finished.
    questionAudio: {fileID: 8300000, guid: b990c81a868f6a6428b4797640a853a3, type: 3}
    correctAnswerIndex: 0
  - question: A boy sees a box of candies meant for everyone. He quietly takes more
      candies than allowed and hides them in his bag.
    questionAudio: {fileID: 8300000, guid: 4898aabba0d89424689a4978ecfe2818, type: 3}
    correctAnswerIndex: 1
  - question: A girl makes a mistake while doing a class activity. She tells the
      teacher what she did wrong and says sorry for the mistake.
    questionAudio: {fileID: 8300000, guid: d477c379f2a8ac546992b9f31275f7b3, type: 3}
    correctAnswerIndex: 0
  correctFeedbackLines:
  - Awesome! That was a great choice!
  - "Yay! You\u2019re becoming a real superhero!"
  - Perfect! Your honesty is making you stronger!
  wrongFeedbackLines:
  - "Oops! That\u2019s not quite right!"
  - Hmm... we can do better next time!
  - "Almost there! Let\u2019s choose more honestly!"
  feedbackFadeDuration: 0.25
